# .env — local development overrides
# Copy this file to .env and fill in values.
# NEVER commit the real .env to version control.

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a real secret with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_TTL_MINUTES=15

# ─── OPA sidecar ─────────────────────────────────────────────────────────────
# When running locally (not via docker-compose), use localhost.
# docker-compose sets this automatically to http://opa:8181.
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=v1/data/agent/authz

# ─── Audit log ────────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=audit.log

# ─── Kubernetes ───────────────────────────────────────────────────────────────
# Set to true only when running INSIDE a Kubernetes pod (in-cluster config).
K8S_IN_CLUSTER=false
